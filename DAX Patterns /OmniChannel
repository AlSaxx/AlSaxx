// Omnichannel Semantic Model — Power BI
// Full DAX measure catalogue, exported via DAX Studio (EVALUATE against $SYSTEM.MDSCHEMA_MEASURES)
//
// ANONYMISED: employer, brand names and the retail partner name have been replaced with
// generic placeholders (Brand A / Brand B / Retail Partner) throughout, including inside
// measure names. Structure, technique and logic are unchanged from the production model.
//
// Tracks vehicle Order-to-Purchase (OTP) conversion across the sales and lead pipeline,
// with year-on-year comparisons, conditional-formatting helper measures for report visuals
// (colour-coded and arrow-coded YoY indicators), and brand/retail-partner-level splits using
// USERELATIONSHIP for a customer table with an alternate active date relationship.
//
// Also includes a Calculation Group (Time Intelligence) — a single set of calculation items
// applying R6M / MTD / QTD / YTD / Dynamic period-shift logic to whichever measure the report
// has selected (SELECTEDMEASURE()), rather than duplicating each period variant per measure.
// Uses an inactive relationship (DIM_Inactive_Masterdate) activated per calculation item via
// USERELATIONSHIP, avoiding ambiguous active relationships on the date dimension.

//==============================================================================
// ORDER-TO-PURCHASE CORE MEASURES
//==============================================================================

// ---- Abandoned Orders ----
Abandoned Orders :=
[Total Orders]-[Total Valid Orders]

// ---- Avg (Weighted) Difference Order & Sales Value ----
Avg (Weighted) Difference Order & Sales Value :=
CALCULATE (
   AVERAGEX ( FCT_Transactions, FCT_Transactions[d_InvoiceValue] - FCT_Transactions[o_Price] ),
   FCT_Transactions[Order to Purchase Filter]
       IN {
           "Order to Purchase",
           "Lead Enabled Order to Purchase",
           "Order to Purchase - Diff Car",
           "Lead Enabled Order to Purchase - Diff Car"
       }
)

// ---- Avg Days Order to Purchase ----
Avg Days Order to Purchase :=
CALCULATE (
                               AVERAGE (FCT_Transactions[OrdertoPurchaseDays]),
                               FCT_Transactions[Order to Purchase Filter] IN {
                                                                               "Order to Purchase",
                                                                               "Lead Enabled Order to Purchase",
                                                                               "Order to Purchase - Diff Car",
                                                                               "Lead Enabled Order to Purchase - Diff Car"
                                                                               }
                               )

// ---- AVG Order Value ----
AVG Order Value :=
CALCULATE (
   AVERAGEX ( FCT_Transactions, FCT_Transactions[o_Price] ),
   FCT_Transactions[Order to Purchase Filter]
       IN {
           "Order to Purchase",
           "Lead Enabled Order to Purchase",
           "Order to Purchase - Diff Car",
           "Lead Enabled Order to Purchase - Diff Car"
       }
)

// ---- AVG Sales Value ----
AVG Sales Value :=
VAR table_ORS =
   SELECTCOLUMNS (
       CALCULATETABLE (
           FCT_Transactions,
           FCT_Transactions[Order to Purchase Filter]
               IN {
                   "Order to Purchase",
                   "Lead Enabled Order to Purchase",
                   "Order to Purchase - Diff Car",
                   "Lead Enabled Order to Purchase - Diff Car"
               }
               ),
           "d_InvoiceValue", FCT_Transactions[d_InvoiceValue]
       )
RETURN
   AVERAGEX(table_ORS,[d_InvoiceValue])

