//==============================================================================
// CALCULATION GROUP: TIME INTELLIGENCE
//==============================================================================
// Calculation items applying period-shift logic to whichever measure the report has
// selected, via SELECTEDMEASURE(). Uses an inactive relationship on the date dimension
// (DIM_Inactive_Masterdate), activated per item with USERELATIONSHIP.

// ---- R6M ----
R6M =
VAR referenceDate = MAX(DIM_Masterdate[Date])

VAR previousDates =
    DATESINPERIOD(
        DIM_Inactive_Masterdate[Date],
        referenceDate,
        -6,
        MONTH
    )

RETURN
CALCULATE(
    CALCULATE(SELECTEDMEASURE(),
        DATESINPERIOD (DIM_Masterdate[Date],
        MAX(DIM_Masterdate[Date]),
        -6,
        MONTH)
    ),
    REMOVEFILTERS(DIM_Masterdate),
    KEEPFILTERS(previousDates),
    USERELATIONSHIP(
                    DIM_Masterdate[Date],
                    DIM_Inactive_Masterdate[Date]
                )
        )

// ---- MTD ----
MTD =
VAR referenceDate =
            MAX(DIM_Masterdate[Date])
VAR previousDates =
            DATESINPERIOD(DIM_Inactive_Masterdate[Date],
                            referenceDate,
                            -12,
                            MONTH
                           )
VAR Result =
            CALCULATE(
                SELECTEDMEASURE(),
                REMOVEFILTERS(DIM_Masterdate),
                KEEPFILTERS(previousDates),
                USERELATIONSHIP(DIM_Masterdate[Date],DIM_Inactive_Masterdate[Date])
            )
RETURN
Result

// ---- QTD ----
QTD =
VAR referenceDate = MAX(DIM_Masterdate[Date])

VAR previousDates = DATESQTD(DIM_Masterdate[Date])

RETURN
CALCULATE(
    CALCULATE( SELECTEDMEASURE(),
        DATESQTD( DIM_Masterdate[Date] )
),
    REMOVEFILTERS(DIM_Masterdate),
    KEEPFILTERS(previousDates),
    USERELATIONSHIP(DIM_Masterdate[Date], DIM_Inactive_Masterdate[Date])
    )

// ---- YTD ----
YTD =
VAR referenceDate = MAX( DIM_Masterdate[Date] )

VAR previousDates = DATESYTD(DIM_Masterdate[Date])

RETURN
CALCULATE(
    CALCULATE(SELECTEDMEASURE(),
            DATESYTD( DIM_Masterdate[Date] )
),
    REMOVEFILTERS(DIM_Masterdate),
    KEEPFILTERS(previousDates),
    USERELATIONSHIP(DIM_Masterdate[Date], DIM_Inactive_Masterdate[Date])
    )

// ---- Dynamic ----
Dynamic =
        CALCULATE(
                CALCULATE(
                    SELECTEDMEASURE(),
                    USERELATIONSHIP(
                                    DIM_Inactive_Masterdate[Date],
                                    DIM_Masterdate[Date]
                                    )
                            ),
                FILTER(
                    ALLSELECTED(
                                DIM_Masterdate[Date]),
                    ISONORAFTER(
                                DIM_Masterdate[Date],
                                MAX(DIM_Inactive_Masterdate[Date]),
                                DESC
                                )
                        )
                    )
