//==============================================================================
// CATEGORY SPLITS (SOFTWARE / HARDWARE / ACCESSORY / DIGITAL)
//==============================================================================

// ---- Software Units Sales ----
Software Units Sales :=
CALCULATE(
[Unit Sales],
DIM_PRODUCT[Class Code] = "S"
)

// ---- Hardware Unit sales ----
Hardware Unit sales :=
CALCULATE(
[Unit Sales],
DIM_PRODUCT[Class Code] = "H"
)

// ---- Accessory Unit Sales ----
Accessory Unit Sales :=
CALCULATE(
[Unit Sales],
DIM_PRODUCT[Class Code] = "A"
)

// ---- Accessory Value Sales ----
Accessory Value Sales :=
CALCULATE(
[Value Sales],
DIM_PRODUCT[Class Code] = "A"
)

// ---- Hardware Value sales ----
Hardware Value sales :=
CALCULATE(
[Value Sales],
DIM_PRODUCT[Class Code] = "H"
)

// ---- Software Value Sales ----
Software Value Sales :=
CALCULATE(
[Value Sales],
DIM_PRODUCT[Class Code] = "S"
)

// ---- Digital Download Unit Sales ----
Digital Download Unit Sales :=
CALCULATE(
[Unit Sales],
DIM_PRODUCT[Class Code] = "D"
)

// ---- Digital Download Value Sales ----
Digital Download Value Sales :=
CALCULATE(
[Value Sales],
DIM_PRODUCT[Class Code] = "D"
)

// ---- Software Unit Sales LY ----
Software Unit Sales LY :=
CALCULATE (
   [Software Units Sales],
   DATEADD (
       DIM_DATE[Date],
       -1,
       YEAR
   )
)

// ---- Accessory Unit Sales LY ----
Accessory Unit Sales LY :=
CALCULATE (
   [Accessory Unit Sales],
   DATEADD (
       DIM_DATE[Date],
       -1,
       YEAR
   )
)

// ---- Hardware Unit Sales LY ----
Hardware Unit Sales LY :=
CALCULATE (
   [Hardware Unit sales],
   DATEADD (
       DIM_DATE[Date],
       -1,
       YEAR
   )
)

// ---- Digital Download Unit Sales LY ----
Digital Download Unit Sales LY :=
CALCULATE (
   [Digital Download Unit Sales],
   DATEADD (
       DIM_DATE[Date],
       -1,
       YEAR
   )
)

// ---- YoY Software Unit Growth % ----
YoY Software Unit Growth % :=
VAR LYSUnit =
   CALCULATE (
       [Software Units Sales],
       DATEADD (
           DIM_DATE[Date],
           -1,
           YEAR
       )
   )
RETURN
DIVIDE (
       ( [Software Units Sales] - LYSUnit ),
       LYSUnit
   )

// ---- PS4 Software Units ----
PS4 Software Units :=
CALCULATE(
[Software Units Sales],
SoftwareSKU[SUBCLASS_CODE] = "PS4"
)

// ---- PS5 Software Units ----
PS5 Software Units :=
CALCULATE(
[Software Units Sales],
SoftwareSKU[SUBCLASS_CODE] = "PS5"
)


//==============================================================================
// MARKET BASKET ANALYSIS (SUPPORT / CONFIDENCE / LIFT)
//==============================================================================

// ---- Orders And ----
Orders And :=
CALCULATE (
   [Orders (No Return Count)],
   ALL ( 'DIM_PRODUCT' ),
   USERELATIONSHIP ( FCT_SALES_LINES[Product Key], 'DIM_ANDPRODUCT'[AND Product Key] )
)

// ---- Orders Both (Internal) ----
Orders Both (Internal) :=
VAR OrderswithAndProducts =
   CALCULATETABLE (
       SUMMARIZE (
           FCT_SALES_LINES,
           FCT_SALES_LINES[Invoice No]
       ),
       ALL ( 'DIM_PRODUCT' ),
       ALL ( 'FCT_SALES_LINES'[Product Key] ),
       USERELATIONSHIP ( FCT_SALES_LINES[Product Key], 'DIM_ANDPRODUCT'[AND Product Key] )
   )
VAR Result =
   CALCULATE (
       [Orders (No Return Count)],
       KEEPFILTERS ( OrderswithAndProducts )
   )
RETURN
   Result

// ---- Orders Both ----
Orders Both :=
IF (
   ISEMPTY (
       INTERSECT (
           DISTINCT ( 'DIM_PRODUCT'[Product Key] ),
           DISTINCT ( 'DIM_ANDPRODUCT'[AND Product Key] )
       )
   ),
   [Orders Both (Internal)]
)

// ---- % Orders Support ----
% Orders Support :=
DIVIDE ([Orders Both], [Orders Total])

// ---- % Orders Confidence ----
% Orders Confidence :=
DIVIDE ([Orders Both], [Orders (No Return Count)])

// ---- Orders Lift ----
Orders Lift :=
DIVIDE (
   [% Orders Confidence],
   DIVIDE (
       [Orders And],
       [Orders Total]
   )
)

// ---- Store Orders Both (Internal) ----
Store Orders Both (Internal) :=
VAR OrderswithAndProducts =
   CALCULATETABLE (
       SUMMARIZE (
           FCT_SALES_LINES,
           FCT_SALES_LINES[Invoice No]
       ),
       ALL ( 'DIM_PRODUCT' ),
       ALL ( 'FCT_SALES_LINES'[Product Key] ),
       USERELATIONSHIP ( FCT_SALES_LINES[Product Key], 'DIM_ANDPRODUCT'[AND Product Key] )
   )
VAR Result =
   CALCULATE (
       [Store Orders (No Return Count)],
       KEEPFILTERS ( OrderswithAndProducts )
   )
RETURN
   Result

// ---- Store Orders Both ----
Store Orders Both :=
IF (
   ISEMPTY (
       INTERSECT (
           DISTINCT ( 'DIM_PRODUCT'[Product Key] ),
           DISTINCT ( 'DIM_ANDPRODUCT'[AND Product Key] )
       )
   ),
   [Store Orders Both (Internal)]
)

// ---- Store Orders And ----
Store Orders And :=
CALCULATE (
   [Store Orders (No Return Count)],
   ALL ( 'DIM_PRODUCT' ),
   USERELATIONSHIP ( FCT_SALES_LINES[Product Key], 'DIM_ANDPRODUCT'[AND Product Key] )
)

// ---- % Store Orders Confidence ----
% Store Orders Confidence :=
DIVIDE ([Store Orders Both], [Store Orders (No Return Count)])

// ---- Online Orders And ----
Online Orders And :=
CALCULATE (
   [Online Orders (No Return Count)],
   ALL ( 'DIM_PRODUCT' ),
   USERELATIONSHIP ( FCT_SALES_LINES[Product Key], 'DIM_ANDPRODUCT'[AND Product Key] )
)

// ---- Online Orders Both (Internal) ----
Online Orders Both (Internal) :=
VAR OrderswithAndProducts =
   CALCULATETABLE (
       SUMMARIZE (
           FCT_SALES_LINES,
           FCT_SALES_LINES[Invoice No]
       ),
       ALL ( 'DIM_PRODUCT' ),
       ALL ( 'FCT_SALES_LINES'[Product Key] ),
       USERELATIONSHIP ( FCT_SALES_LINES[Product Key], 'DIM_ANDPRODUCT'[AND Product Key] )
   )
VAR Result =
   CALCULATE (
       [Online Orders (No Return Count)],
       KEEPFILTERS ( OrderswithAndProducts )
   )
RETURN
   Result

// ---- Online Orders Both ----
Online Orders Both :=
IF (
   ISEMPTY (
       INTERSECT (
           DISTINCT ( 'DIM_PRODUCT'[Product Key] ),
           DISTINCT ( 'DIM_ANDPRODUCT'[AND Product Key] )
       )
   ),
   [Online Orders Both (Internal)]
)

// ---- % Online Order Confidence ----
% Online Order Confidence :=
DIVIDE ([Online Orders Both], [Online Orders (No Return Count)])


//==============================================================================
// ORDER COUNTS & RETURNS HANDLING
//==============================================================================

// ---- Orders (No Return Count) ----
Orders (No Return Count) :=
CALCULATE (
   SUMX (
       SUMMARIZE (
            FCT_SALES_LINES,
            FCT_SALES_LINES[Invoice No]
       ),
        1
   ),
   NOT CONTAINSROW (
       {
           "DISC-RET",
           "REG-RET"
       },
       FCT_SALES_LINES[Invoice Type]
   )
)

// ---- Orders Total ----
Orders Total :=
CALCULATE (
   [Orders (No Return Count)],
   ALL ( 'DIM_PRODUCT' )
)

// ---- Online Orders (No Return Count) ----
Online Orders (No Return Count) :=
CALCULATE(
[Orders (No Return Count)],
CONTAINSROW({"UK - 887", "UK - 889"}, FCT_SALES_LINES[Store Code]
)
)

// ---- Store Orders (No Return Count) ----
Store Orders (No Return Count) :=
CALCULATE(
[Orders (No Return Count)],
NOT CONTAINSROW({"UK - 887","UK - 889"}, FCT_SALES_LINES[Store Code]
)
)

// ---- Unit Sales (No Returns) ----
Unit Sales (No Returns) :=
CALCULATE(
[Unit Sales],
NOT CONTAINSROW(
{"DISC-RET",
"REG-RET"},
FCT_SALES_LINES[Invoice Type]
)
)

// ---- Store Units (No Returns) ----
Store Units (No Returns) :=
CALCULATE(
[Unit Sales (No Returns)],
NOT CONTAINSROW(
{"UK - 887",
"UK - 889"},
FCT_SALES_LINES[Store Code]
)
)

// ---- Online Units (No Returns) ----
Online Units (No Returns) :=
CALCULATE (
   [Unit Sales (No Returns)],
   CONTAINSROW (
       {
           "UK - 887",
           "UK - 889"
       },
       FCT_SALES_LINES[Store Code]
   )
)

