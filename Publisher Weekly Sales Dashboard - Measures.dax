Software Online Unit Sales % :=
VAR OSUPSales =
    CALCULATE (
       [Software Units Sales],
        CONTAINSROW (
           {
               "UK - 887",
               "UK - 889"
           },
            FCT_SALES_LINES[Store Code]
       )
