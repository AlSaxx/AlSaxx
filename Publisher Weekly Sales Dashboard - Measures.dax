// Publisher Weekly Sales Dashboard — Power Pivot / Power Query Excel BI tool
// Full DAX measure catalogue, exported via DAX Studio (EVALUATE against $SYSTEM.MDSCHEMA_MEASURES)
// Built as a partner-facing dashboard, and as a low-friction stepping stone toward Power BI adoption.
// Star schema: FCT_SALES_LINES fact table against DIM_DATE / DIM_PRODUCT, with category-specific
// bridge tables (SoftwareSKU, HardwareSKU, AccessorySKU, DigitalSKU) and a secondary product
// taxonomy (DIM_ANDPRODUCT) resolved via USERELATIONSHIP for market-basket analysis.

//==============================================================================
// BASE MEASURES
//==============================================================================

// ---- Sum of Sales Quantity ----
Sum of Sales Quantity :=
SUM('FCT_SALES_LINES'[Sales Quantity])

// ---- Sum of Gross Value ----
Sum of Gross Value :=
SUM('FCT_SALES_LINES'[Gross Value])

// ---- Sum of Net Value ----
Sum of Net Value :=
SUM('FCT_SALES_LINES'[Net Value])

// ---- Unit Sales ----
Unit Sales :=
SUM(FCT_SALES_LINES[Sales Quantity])

// ---- Value Sales ----
Value Sales :=
SUM(FCT_SALES_LINES[Gross Value])

// ---- Average Basket Units ----
Average Basket Units :=
AVERAGEX(
DISTINCT(FCT_SALES_LINES[Invoice No]),
[Unit Sales]
)

// ---- Average Basket Value ----
Average Basket Value :=
AVERAGEX(
DISTINCT(FCT_SALES_LINES[Invoice No]),
[Value Sales]
)


//==============================================================================
// TIME INTELLIGENCE (YOY / WOW / YTD / MTD)
//==============================================================================

// ---- Unit Sales LY ----
Unit Sales LY :=
CALCULATE (
   [Unit Sales],
   DATEADD (
       DIM_DATE[Date],
       -1,
       YEAR
   )
)

// ---- Value LY ----
Value LY :=
CALCULATE (
   [Value Sales],
   DATEADD (
       DIM_DATE[Date],
       -1,
       YEAR
   )
)

// ---- Unit Sales LW ----
Unit Sales LW :=
CALCULATE (
   [Unit Sales],
   DATEADD (
       DIM_DATE[Date],
       -7,
       DAY
   )
)

// ---- Value Sales LW ----
Value Sales LW :=
CALCULATE (
   [Value Sales],
   DATEADD (
       DIM_DATE[Date],
       -7,
       DAY
   )
)

// ---- YoY Unit Growth % ----
YoY Unit Growth % :=
VAR LYUnit =
   CALCULATE (
       [Unit Sales],
       DATEADD (
           DIM_DATE[Date],
           -1,
           YEAR
       )
   )
RETURN
   DIVIDE (
       ( [Unit Sales] - LYUnit ),
       LYUnit
   )

// ---- YoY Value Growth % ----
YoY Value Growth % :=
VAR LYGross =
   CALCULATE (
       [Value Sales],
       DATEADD (
           DIM_DATE[Date],
           -1,
           YEAR
       )
   )
RETURN
   DIVIDE (
       ( [Value Sales] - LYGross ),
       LYGross
   )

// ---- WoW Unit Growth % ----
WoW Unit Growth % :=
VAR LWUnit =
   CALCULATE (
       [Unit Sales],
       DATEADD (
           DIM_DATE[Date],
           -7,
           DAY
       )
   )
RETURN
   DIVIDE (
       ( [Unit Sales] - LWUnit ),
       LWUnit
   )

// ---- Unit Sales YTD ----
Unit Sales YTD :=
CALCULATE(
[Unit Sales],
DATESYTD(DIM_DATE[Date])
)

// ---- Value Sales YTD ----
Value Sales YTD :=
CALCULATE(
[Value Sales],
DATESYTD(DIM_DATE[Date])
)

// ---- Unit Sales LW LY ----
Unit Sales LW LY :=
CALCULATE(
[Unit Sales],
SAMEPERIODLASTYEAR(DIM_DATE[Date])
)

// ---- YoY Week Unit Growth % ----
YoY Week Unit Growth % :=
VAR Num = [Unit Sales]-[Unit Sales LW LY]
RETURN
DIVIDE(Num, [Unit Sales LW LY])

// ---- Unit Sales YTD LY ----
Unit Sales YTD LY :=
CALCULATE (
   [Unit Sales],
   SAMEPERIODLASTYEAR (
       DATESYTD ( DIM_DATE[Date] )
   )
)

// ---- Unit Sales YTD YoY ----
Unit Sales YTD YoY :=
VAR Num = [Unit Sales YTD]-[Unit Sales YTD LY]
RETURN
DIVIDE(Num, [Unit Sales YTD LY])

// ---- WoW Value Growth % ----
WoW Value Growth % :=
VAR LWVal =
   CALCULATE (
       [Value Sales],
       DATEADD (
           DIM_DATE[Date],
           -7,
           DAY
       )
   )
RETURN
DIVIDE (
       ( [Value Sales] - LWVal ),
       LWVal
)

// ---- Value Sales LW LY ----
Value Sales LW LY :=
CALCULATE(
[Value Sales],
SAMEPERIODLASTYEAR(DIM_DATE[Date])
)

// ---- YoY Week Value Growth % ----
YoY Week Value Growth % :=
VAR Num = [Value Sales]-[Value Sales LW LY]
RETURN
DIVIDE(Num, [Value Sales LW LY])

// ---- Value Sales YTD LY ----
Value Sales YTD LY :=
CALCULATE (
   [Value Sales],
   SAMEPERIODLASTYEAR (
       DATESYTD ( DIM_DATE[Date] )
   )
)

// ---- Value Sales YTD YoY ----
Value Sales YTD YoY :=
VAR Num = [Value Sales YTD]-[Value Sales YTD LY]
RETURN
DIVIDE(Num, [Value Sales YTD LY])

// ---- Unit Sales MTD ----
Unit Sales MTD :=
CALCULATE(
[Unit Sales],
DATESMTD(DIM_DATE[Date])
)

// ---- Value Sales MTD ----
Value Sales MTD :=
CALCULATE(
[Value Sales],
DATESMTD(DIM_DATE[Date])
)


//==============================================================================
// CHANNEL SPLIT (ONLINE VS STORE)
//==============================================================================

// ---- Online Units ----
Online Units :=
CALCULATE(
[Unit Sales],
CONTAINSROW(
{
"UK - 887",
"UK - 889"
},
FCT_SALES_LINES[Store Code]
)
)

// ---- Store Units ----
Store Units :=
CALCULATE(
[Unit Sales],
NOT CONTAINSROW(
{
"UK - 887",
"UK - 889"
},
FCT_SALES_LINES[Store Code]
)
)

// ---- Online Unit Sales % ----
Online Unit Sales % :=
VAR OUPSales =
    CALCULATE (
       [Unit Sales],
        CONTAINSROW (
           {
               "UK - 887",
               "UK - 889"
           },
            FCT_SALES_LINES[Store Code]
       )
   )
   
RETURN
    DIVIDE (
        OUPSales,
        [Unit Sales]
   )

// ---- Store Unit Sales % ----
Store Unit Sales % :=
VAR SUPSales =
    CALCULATE (
        [Unit Sales],
        NOT CONTAINSROW (
           {
               "UK - 887",
               "UK - 889"
           },
            FCT_SALES_LINES[Store Code]
       )
   )
   
RETURN
   DIVIDE (
       SUPSales,
        FCT_SALES_LINES[Unit Sales]
   )

// ---- Online Value Sales % ----
Online Value Sales % :=
VAR OVPSales =
    CALCULATE (
       [Value Sales],
        CONTAINSROW (
           {
               "UK - 887",
               "UK - 889"
           },
            FCT_SALES_LINES[Store Code]
       )
   )
   
RETURN
    DIVIDE (
        OVPSales,
        [Value Sales]
   )

// ---- Store Value Sales % ----
Store Value Sales % :=
VAR SVPSales =
    CALCULATE (
        [Value Sales],
        NOT CONTAINSROW (
           {
               "UK - 887",
               "UK - 889"
           },
            FCT_SALES_LINES[Store Code]
       )
   )
   
RETURN
   DIVIDE (
       SVPSales,
        FCT_SALES_LINES[Value Sales]
   )

