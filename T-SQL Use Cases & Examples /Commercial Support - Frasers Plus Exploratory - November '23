USE GAME_ARC
GO

SELECT	CAST(D.DATE_FLD as date) 'tDate',
		T.TENDER_NAME,
		COUNT(DISTINCT F.INVOICE_NO) AS 'Transactions',
		SUM(F.SALE_TOT_QTY) 'Units',
		SUM(F.SALE_NET_VAL+F.SALE_TOT_TAX_VAL) 'Gross_Val'
	FROM FCT_SALES_LINES F (NOLOCK)
		INNER JOIN FCT_SALES_INVOICE_TENDER IT (NOLOCK) ON IT.INVOICE_NO = F.INVOICE_NO
		INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
			AND D.DATE_KEY = IT.DATE_KEY
		INNER JOIN DIM_TENDER T (NOLOCK) ON T.TENDER_KEY = IT.TENDER_KEY
	WHERE D.DATE_FLD >= '2023-11-03' AND D.DATE_FLD < GETDATE()			-- Launch Date to present
		AND F.SALE_INVC_TYPE IN ('REG-INV', 'DISC-SALE')
		AND T.TENDER_CODE = 'CN'										-- Frasers Plus
	GROUP BY
		D.DATE_FLD,
		T.TENDER_NAME
	ORDER BY
		tDate
GO

SELECT	P.SOURCE_PRODUCT_CODE 'SKU',
		P.PRODUCT_DESCRIPTION,
		P.CLASS_DESC,
		SUM(F.SALE_TOT_QTY) 'Units'
	FROM FCT_SALES_LINES F (NOLOCK)
		INNER JOIN FCT_SALES_INVOICE_TENDER IT (NOLOCK) ON IT.INVOICE_NO  = F.INVOICE_NO
		INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
			AND D.DATE_KEY = IT.DATE_KEY
		INNER JOIN DIM_TENDER T (NOLOCK) ON T.TENDER_KEY = IT.TENDER_KEY
		INNER JOIN DIM_PRODUCT P (NOLOCK) ON P.PRODUCT_KEY = F.PRODUCT_KEY
	WHERE D.DATE_FLD >= '2023-11-03' AND D.DATE_FLD < GETDATE()			-- Launch Date to present
		AND F.SALE_INVC_TYPE IN ('REG-INV', 'DISC-SALE')
		AND T.TENDER_CODE = 'CN'										-- Frasers Plus
		AND PROD_TYPE_CODE NOT IN ('326','328')							-- P&P, Loyalty
		AND SUBCLASS_CODE NOT IN ('OMF')
	GROUP BY
		P.SOURCE_PRODUCT_CODE,
		P.PRODUCT_DESCRIPTION,
		P.CLASS_DESC
	ORDER BY
		Units DESC
GO

