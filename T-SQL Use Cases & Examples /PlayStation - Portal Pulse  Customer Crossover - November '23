SELECT COUNT(DISTINCT mergedCustomerId) 'Portal_Cust'
	FROM #POR
GO

SELECT COUNT(DISTINCT mergedCustomerId) 'Pulse_Cust'
	FROM #PUL
GO

SELECT COUNT(DISTINCT mergedCustomerId) 'XOver_Cust'
	FROM #POR
	WHERE mergedCustomerId IN (SELECT mergedCustomerId FROM #PUL)
GO

