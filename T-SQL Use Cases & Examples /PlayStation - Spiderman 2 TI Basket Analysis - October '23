USE GAME_ARC
GO

----------------------------------------------PRODUCT TABLES-------------------------------------------
-------------------------------------------------------------------------------------------------------

IF OBJECT_ID ('tempdb..#SM2') IS NOT NULL
    DROP TABLE #SM2

SELECT *																														-- Spider-man 2 MINT SKU 
    INTO #SM2
        FROM DIM_PRODUCT
		WHERE SOURCE_PRODUCT_CODE IN ('832901')
GO

----------------------------------------------BASKET TABLES--------------------------------------------
-------------------------------------------------------------------------------------------------------

IF OBJECT_ID ('tempdb..#BSKT') IS NOT NULL																						-- Spider-man 2 Baskets
	DROP TABLE #BSKT

SELECT DISTINCT F.INVOICE_NO
    INTO #BSKT
        FROM FCT_SALES_LINES F (NOLOCK)
            INNER JOIN #SM2 AS S ON S.PRODUCT_KEY = F.PRODUCT_KEY
            INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
        WHERE D.DATE_FLD >= '2023-10-20' AND D.DATE_FLD < '2023-10-31'
GO

-------------------------------------------------------------------------------------------------------
-------------------------------------------------------------------------------------------------------

SELECT COUNT(DISTINCT INVOICE_NO) AS 'SM2_BSKT'																-- SM2 Basket Count
	FROM #BSKT
GO

SELECT COUNT(DISTINCT F.INVOICE_NO) AS 'TI_BSKT'
	FROM FCT_SALES_LINES F (NOLOCK)
		INNER JOIN #BSKT B ON B.INVOICE_NO = F.INVOICE_NO
	WHERE
		SALE_INVC_TYPE = 'TRADE-IN'
GO

SELECT P.PRODUCT_CODE, P.PRODUCT_DESCRIPTION, -SUM(F.SALE_TOT_QTY) 'TI_Units'
	FROM FCT_SALES_LINES F (NOLOCK)
		INNER JOIN #BSKT B ON B.INVOICE_NO = F.INVOICE_NO
		INNER JOIN DIM_PRODUCT P (NOLOCK) ON P.PRODUCT_KEY = F.PRODUCT_KEY
	WHERE
		SALE_INVC_TYPE = 'TRADE-IN'
	GROUP BY
		P.PRODUCT_CODE,
		P.PRODUCT_DESCRIPTION
	ORDER BY
		TI_Units DESC
GO
	
