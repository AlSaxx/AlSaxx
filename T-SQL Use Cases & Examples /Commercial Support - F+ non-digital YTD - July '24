--SELECT * FROM #TTrans

SELECT	D.[YEAR] 'cYr',
		D.[WEEK_NUMBER_THIS_YEAR] 'cWk',
		CASE
			WHEN T.TENDER_CODE = 'CN' THEN 'F+'
			ELSE 'Non-F+'
		END 'Payment',
		COUNT(DISTINCT F.INVOICE_NO) 'Transactions'
	FROM FCT_SALES_LINES F (NOLOCK)
		INNER JOIN FCT_SALES_INVOICE_TENDER IT (NOLOCK) ON F.INVOICE_NO = IT.INVOICE_NO
		INNER JOIN DIM_TENDER T (NOLOCK) ON T.TENDER_KEY = IT.TENDER_KEY
		INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
		INNER JOIN #PROD P ON P.PRODUCT_KEY = F.PRODUCT_KEY
	WHERE
		D.[YEAR] = 2024
		AND F.SALE_INVC_TYPE IN ('REG-INV','DISC-SALE')
	GROUP BY
		D.[YEAR],
		D.[WEEK_NUMBER_THIS_YEAR],
		CASE
			WHEN T.TENDER_CODE = 'CN' THEN 'F+'
			ELSE 'Non-F+'
		END
GO
