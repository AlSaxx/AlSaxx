---------------------------PRODUCT TABLES------------------------------
-----------------------------------------------------------------------

IF OBJECT_ID ('tempdb..#PROD') IS NOT NULL
	DROP TABLE #PROD

SELECT *
	INTO #PROD
	FROM DIM_PRODUCT P (NOLOCK)
	WHERE	P.DEPARTMENT_CODE <> 'D'	
		OR (P.DEPARTMENT_CODE = 'M' 
		AND P.CLASS_CODE NOT IN ('J','B'))
		AND MERCHANDISE_FLG = 'YES'
GO

