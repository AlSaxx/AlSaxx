USE GAME_ARC
GO

IF OBJECT_ID ('tempdb..#PSS') IS NOT NULL
	DROP TABLE #PSS

SELECT *
	FROM
	( 
SELECT PRODUCT_KEY, SOURCE_PRODUCT_CODE, DEPARTMENT_CODE, DEPARTMENT_DESC, CLASS_CODE, CLASS_DESC, SUBCLASS_CODE, SUBCLASS_DESC, MANUFACTURE_CODE, ATTRIB1_CODE, ATTRIB1_DESC
	FROM   dbo.DIM_PRODUCT AS P
		WHERE DEPARTMENT_CODE = 'M'
			AND SUBCLASS_CODE IN ( 'PS4', 'PS5')
			AND SUBCLASS_CODE <> 'VR'
			AND P.MERCHANDISE_FLG = 'YES'
			AND MANUFACTURE_CODE = 400079
			AND PROD_TYPE_CODE NOT IN (445,470)
                        AND LATEST = 1
			) a

UNION ALL

SELECT *
	FROM ( 
SELECT PRODUCT_KEY, SOURCE_PRODUCT_CODE,
		DEPARTMENT_CODE,
		DEPARTMENT_DESC,
		CASE
			WHEN CLASS_CODE = 'H' THEN 'A' END AS 'CLASS_CODE',
		CASE
			WHEN CLASS_DESC = 'Hardware' THEN 'Accessories' END AS 'CLASS_DESC',
		SUBCLASS_CODE,
		SUBCLASS_DESC,
		MANUFACTURE_CODE,
		ATTRIB1_CODE,
		ATTRIB1_DESC
	FROM   dbo.DIM_PRODUCT AS P
		WHERE DEPARTMENT_CODE = 'M'
			AND SUBCLASS_CODE = 'VR'
			AND P.MERCHANDISE_FLG = 'YES'
			AND MANUFACTURE_CODE = 400079
			AND PROD_TYPE_CODE NOT IN (445,470)
                        AND LATEST = 1
			) b

UNION ALL

SELECT *
FROM (
SELECT PRODUCT_KEY, SOURCE_PRODUCT_CODE, DEPARTMENT_CODE, DEPARTMENT_DESC, CLASS_CODE, CLASS_DESC, SUBCLASS_CODE, SUBCLASS_DESC, MANUFACTURE_CODE, ATTRIB1_CODE, ATTRIB1_DESC
	FROM   dbo.DIM_PRODUCT AS P
		WHERE DEPARTMENT_CODE = 'D'
			AND CLASS_CODE = 'N'
			AND SUBCLASS_CODE IN ( 'PS3', 'PS4', 'PS5' )
			AND P.MERCHANDISE_FLG = 'YES'
			AND MANUFACTURE_CODE IN (400079,500350,500352)
			AND P.PRODUCT_KEY NOT IN (SELECT DISTINCT PRODUCT_KEY FROM DIM_PRODUCT WHERE PROD_TYPE_CODE = 470 and ATTRIB1_CODE = 50)
			AND LATEST = 1
) c




















SELECT CAST(DATE_FLD AS date) AS 'tDate', DATEPART(WEEK,DATE_FLD) AS 'Wk', SUM(SALE_TOT_QTY) AS 'Unit_Sales'
	FROM FCT_SALES_LINES AS F
		INNER JOIN DIM_DATE AS D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
		INNER JOIN DIM_PRODUCT AS P (NOLOCK) ON P.PRODUCT_KEY = F.PRODUCT_KEY
	WHERE D.DATE_FLD >= DATEADD(YEAR, -2, DATEADD(day, -1, GETDATE())) AND D.DATE_FLD < GETDATE()
		AND MANUFACTURE_CODE IN (400079, 500350, 500352)
	GROUP BY
		CAST(DATE_FLD AS date),
		DATEPART(WEEK,DATE_FLD)
	ORDER BY
		tDate,
		Wk
GO
