--------------------------AGGERGATE TABLES--------------------------------
--------------------------------------------------------------------------

IF OBJECT_ID ('tempdb..#SX1') IS NOT NULL
	DROP TABLE #SX1

SELECT	D.DATE_KEY,
		CAST(D.DATE_FLD as date) 'tDate',
		CAST(COUNT(DISTINCT F.INVOICE_NO) AS numeric (5,1)) 'X_BSKT'
	INTO #SX1
	FROM FCT_SALES_LINES F (NOLOCK)
		INNER JOIN #XBSKT B ON B.INVOICE_NO = F.INVOICE_NO
		INNER JOIN #SX P ON P.PRODUCT_KEY = F.PRODUCT_KEY
		INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
	WHERE
		D.DATE_FLD >= '2023-11-10' AND D.DATE_FLD < '2023-11-20'
	GROUP BY
		D.DATE_KEY,
		D.DATE_FLD
	ORDER BY
		tDate
GO

