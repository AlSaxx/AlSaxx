SELECT	tDate,
		Series_X,
		COALESCE([Non-F+],0) 'Non-F+',
		COALESCE([Frasers+],0) 'Frasers+'
FROM
(
SELECT	CAST(D.DATE_FLD AS date) 'tDate',
		CASE
			WHEN SOURCE_PRODUCT_CODE IN ('800821','826515','830005') THEN 'Total_X'
		END 'Series_X',
		CASE
			WHEN T.TENDER_CODE = 'CN' THEN 'Frasers+'
			ELSE 'Non-F+'
		END 'Payment',
		COUNT(DISTINCT F.INVOICE_NO) 'Baskets'
	FROM FCT_SALES_LINES F (NOLOCK)
		INNER JOIN #XBSKT B ON B.INVOICE_NO = F.INVOICE_NO
		INNER JOIN FCT_SALES_INVOICE_TENDER IT (NOLOCK) ON IT.INVOICE_NO  = F.INVOICE_NO
		INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
			AND D.DATE_KEY = IT.DATE_KEY
		INNER JOIN DIM_TENDER T (NOLOCK) ON T.TENDER_KEY = IT.TENDER_KEY
		INNER JOIN DIM_PRODUCT P (NOLOCK) ON P.PRODUCT_KEY = F.PRODUCT_KEY
	WHERE D.DATE_FLD >= '2023-11-10' AND D.DATE_FLD < '2023-11-20'
		AND F.SALE_INVC_TYPE IN ('REG-INV','DISC-SALE')
		AND MERCHANDISE_FLG = 'YES'
		AND SOURCE_PRODUCT_CODE IN (SELECT SOURCE_PRODUCT_CODE FROM #SX)
	GROUP BY
		D.DATE_FLD,
		CASE
			WHEN SOURCE_PRODUCT_CODE IN ('800821','826515','830005') THEN 'Total_X'
		END,
		CASE
			WHEN T.TENDER_CODE = 'CN' THEN 'Frasers+'
			ELSE 'Non-F+'
		END
) A
PIVOT
( 
		SUM(Baskets)
		FOR [Payment] IN (
							[Frasers+],
							[Non-F+]
						)
) PVT
	ORDER BY
		tDate
GO
