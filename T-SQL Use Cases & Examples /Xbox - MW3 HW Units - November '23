--------------------------------DATA PULLS--------------------------------
--------------------------------Unit Sales--------------------------------

SELECT	tDate,
		COALESCE([HW XB4 SERIES X CONSOLE],0) 'Series_X',
		COALESCE([HW XB4 XBOX SRS X FRZ HRZN 5],0) 'Series_X_Forza',
		COALESCE([HW XB4 SERIES DIABLO IV BUND],0) 'Series_X_Diablo4'
FROM
	(
	SELECT	CAST(D.DATE_FLD AS date) 'tDate',
			CASE
				WHEN SOURCE_PRODUCT_CODE = '800821' THEN 'HW XB4 SERIES X CONSOLE'
				WHEN SOURCE_PRODUCT_CODE = '826515' THEN 'HW XB4 XBOX SRS X FRZ HRZN 5'
				WHEN SOURCE_PRODUCT_CODE = '830005'	THEN 'HW XB4 SERIES DIABLO IV BUND'
			END 'XHW',
			SUM(F.SALE_TOT_QTY) 'X_Units'
		FROM FCT_SALES_LINES F (NOLOCK)
			INNER JOIN #XBSKT XB ON XB.INVOICE_NO = F.INVOICE_NO
			INNER JOIN #SX P ON P.PRODUCT_KEY = F.PRODUCT_KEY
			INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
		WHERE D.DATE_FLD >= '2023-10-31' AND D.DATE_FLD < '2023-11-20'
			AND SALE_INVC_TYPE IN ('REG-INV','DISC-SALE')
			AND MERCHANDISE_FLG = 'YES'
		GROUP BY
			D.DATE_FLD,
			CASE
				WHEN SOURCE_PRODUCT_CODE = '800821' THEN 'HW XB4 SERIES X CONSOLE'
				WHEN SOURCE_PRODUCT_CODE = '826515' THEN 'HW XB4 XBOX SRS X FRZ HRZN 5'
				WHEN SOURCE_PRODUCT_CODE = '830005'	THEN 'HW XB4 SERIES DIABLO IV BUND'
			END
	) A
PIVOT
	(	SUM(X_Units)
		FOR XHW IN (
					[HW XB4 SERIES X CONSOLE],
					[HW XB4 XBOX SRS X FRZ HRZN 5],
					[HW XB4 SERIES DIABLO IV BUND]
					)
	) PVT
	ORDER BY
		tDate
GO
--------------------------------Basket Counts-----------------------------

SELECT	tDate,
		COALESCE(X_BSKT,0) 'Series_X', 
		COALESCE(MW3P_BSKT,0) 'MW3_Physical',
		COALESCE(CAST((MW3P_BSKT/X_BSKT)*100 AS numeric (5,1)),0) '%Pen_Phys',
		COALESCE(MW3C_BSKT,0) 'MW3_C2C',
		COALESCE(CAST((MW3C_BSKT/X_BSKT)*100 AS numeric (5,1)),0) '%Pen_C2C',
		COALESCE(CAST((MW3P_BSKT+MW3C_BSKT)/X_BSKT*100 AS numeric (5,1)),0) 'TOT_%Pen'
	FROM #SX1 x
		LEFT OUTER JOIN #MW3P P ON P.DATE_KEY = x.DATE_KEY
		LEFT OUTER JOIN #MW3C C ON C.DATE_KEY = x.DATE_KEY
	GROUP BY
		tDate,
		X_BSKT,
		MW3P_BSKT,
		MW3C_BSKT
	ORDER BY
		tDate
GO

