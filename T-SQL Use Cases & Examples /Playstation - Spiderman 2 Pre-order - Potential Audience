if object_id ('tempdb..#PREORDER') is not NULL
	drop table #PREORDER
select
	distinct a.mergedcustomerid
into
	#PREORDER
from
	#ACTIVE_EM a (nolock)
	inner join expanededmergedcustomerids emc (nolock) on a.mergedcustomerid = emc.mergedcustomerid
	inner join transactions tc (nolock) on tc.insightcustomerid = emc.insightcustomerid
	inner join transactionitem ti (nolock) on tc.id = ti.transactionid
	inner join sku s (nolock) on ti.sku = s.sku
where
	s.sku in ('832901','832902','832903')	-- Spiderman 2 SKU's
	and ti.transactiontypeid in (1,2)
