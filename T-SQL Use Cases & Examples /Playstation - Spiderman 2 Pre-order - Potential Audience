select
	count (distinct title) 'assTitles'
from
	#TOPASSTITLES
go

select
	(cast(cust as decimal (10,2)) / trgtCustAct) 'tScore'
from
	(
		select
			count (distinct t.cid) 'Cust'
		from
			#TARGETCUST t
			inner join expanededmergedcustomerids emc (nolock) on t.cid = emc.mergedcustomerid
			inner join transactions tc (nolock) on emc.insightcustomerid = tc.insightcustomerid
			inner join transactionitem ti (nolock) on tc.id = ti.transactionid
			inner join sku s (nolock) on ti.sku = s.sku
			inner join #TOPASSTITLES tat on s.title = tat.title
		where
			transactiondate > cast(dateadd(month,-12,getdate()) as date)
			and	transactiontypeid = 1
			and productclassid = 1
			and productsubclassid = 1	
	)A
cross join
	(
		select
			count (distinct cid) 'trgtCustAct'
		from
			#TRGT_ACT_CUST
	)B
go



