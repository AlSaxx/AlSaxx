if object_id ('tempdb..#TARGETCUST') is not NULL
	drop table #TARGETCUST
select
	distinct emc.mergedcustomerid 'cid'
into
	#TARGETCUST
from
	expanededmergedcustomerids emc (nolock)
	inner join transactions tc (nolock) on emc.insightcustomerid = tc.insightcustomerid
	inner join transactionitem ti (nolock) on tc.id = ti.transactionid
	inner join #TARGETSKU s (nolock) on ti.sku = s.sku
where
	tc.storenumber != 9999
	and emc.mergedcustomerid not in (select mergedcustomerid from insighttemp..gk_customer_blacklist)
	and emc.mergedcustomerid not in (select distinct mergedcustomerid from insighttemp..GK_B2B_suppression)
go



if object_id ('tempdb..#TRGT_ACT_CUST') is not NULL
	drop table #TRGT_ACT_CUST
select
	distinct cid
into
	#TRGT_ACT_CUST
from
	#TARGETCUST t
	inner join expanededmergedcustomerids emc (nolock) on t.cid = emc.mergedcustomerid
	inner join transactions tc (nolock) on emc.insightcustomerid = tc.insightcustomerid
where
	transactiondate > cast(dateadd(month,-12,getdate()) as date)
	and totalamount != 0
	and storenumber <> 9999
go



if object_id ('tempdb..#TOP_PROD') is not NULL
	drop table #TOP_PROD
select
	s.sku,
	s.title,
	count (distinct emc.mergedcustomerid) 'CustCount'
into
	#TOP_PROD
from
	transactions tc (nolock)
	inner join transactionitem ti (nolock) on tc.id = ti.transactionid
	inner join sku s (nolock) on ti.sku = s.sku
	inner join insightcustomer ic (nolock) on tc.insightcustomerid = ic.id
	inner join expanededmergedcustomerids emc (nolock) on ic.id = emc.insightcustomerid
	inner join #TARGETCUST d (nolock) on emc.mergedcustomerid = d.cid
where
	transactiondate > cast(dateadd(month,-12,getdate()) as date)
	and	transactiontypeid = 1
	and productclassid = 1
	and productsubclassid = 1
	and s.title not like 'POB %'
	and	s.sku not in (select sku from sku where departmentid = 470 and subdepartmentid = 50)
	and s.sku not in (select sku from #TARGETSKU)
group by
	s.sku,
	s.title
having 
	sum(quantity) > 20
go



if object_id ('tempdb..#TOPASSTITLES') is not NULL
	drop table #TOPASSTITLES
select
	*,
	row_number() over (order by (cast(cust as decimal (10,2)) / tCust) desc) 'cScoreRank'
into
	#TOPASSTITLES
from
	(
		select
			*,
			(cast(cust as decimal (10,2)) / tCust) 'cScore'
		from
			(
				select
					distinct TP.title,
					sum(TP.CustCount) 'Cust',
					sum(BUSTOT.cust) 'tCust'
				from
					#TOP_PROD TP		
					left outer join
					(
						select
							distinct TP.sku,
							count (distinct emc.mergedcustomerid) as 'cust'	
						from
							expanededmergedcustomerids emc (nolock)
							inner join insightcustomer ic (nolock) on emc.insightcustomerid = ic.id
							inner join transactions tc (nolock) on ic.id = tc.insightcustomerid
							inner join transactionitem ti (nolock) on tc.id = ti.transactionid
							inner join #TOP_PROD TP	on ti.sku = TP.sku		
						where
							transactiondate > cast(dateadd(month,-12,getdate()) as date)
							and
							transactiontypeid = 1
						group by
							TP.sku
					)BUSTOT
						on TP.sku = BUSTOT.sku
				group by
					TP.title
			)SUMM
	)XLT
where
	cScore >= (select cScore from #VARVALS)
	and cust >= (select cust from #VARVALS) 
go




