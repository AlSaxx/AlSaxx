if object_id ('tempdb..#ACTIVE_EM') is not NULL
	drop table #ACTIVE_EM
select
	distinct emc.mergedcustomerid
into
	#ACTIVE_EM
from
	insightcustomer ic (nolock)
	inner join transactions tc (nolock) on ic.id = tc.insightcustomerid
	inner join expanededmergedcustomerids emc (nolock) on tc.insightcustomerid = emc.insightcustomerid
	inner join compositecustomer cc (nolock) on emc.mergedcustomerid = cc.id
where
	tc.transactiondate >= cast(dateadd(month,-18,getdate()) as date)
	and tc.storenumber != 9999
	and ic.email <> ''
	and ic.email is not NULL
	and (cc.dateOfBirth < cast(dateadd(year,-16,getdate()) as date)				--- !!!base around PEGI rating!!!
		or cc.dateOfBirth is NULL
		or cc.dateOfBirth = '')
	and ic.firstName != 'GDPR'
	and ic.lastName != 'GDPR'
	and ic.email != ic.hashedEmail
	and cc.rewardcontactablebyemail = 1
	and ic.id not in (select distinct insightcustomerid from insighttemp..gk_customer_blacklist)
	and ic.email not in (select distinct email from insighttemp..GK_GDPR_SUPPRESSION)
go


