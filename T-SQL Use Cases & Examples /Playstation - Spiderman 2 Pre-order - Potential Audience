if object_id ('tempdb..#TG_X') is not NULL
	drop table #TG_X
select
	distinct mergedcustomerid,
	customerGroup,
	cgID,
	NTILE(20) over(partition by customerGroup order by newid()) 'Xile'
into
	#TG_X
from 
	(
		select distinct mergedcustomerid, 'Spiderman (2018)' 'customerGroup', 1 'cgID' from #PreviousSpM
		union all
		select distinct mergedcustomerid, 'Spiderman 2 Potentials' 'customerGroup', 2 'cgID' from #SpM2_POTENTIAL
		union all
		select distinct mergedcustomerid, 'Action/Adventure PS5' 'customerGroup', 3 'cgID' from #ACTIONADV_PS5
		union all
		select distinct mergedcustomerid, '18-30 Age Group' 'customerGroup', 4 'cgID' from #AgeGroup
		union all
		select distinct mergedcustomerid, 'PS5' 'customerGroup', 5 'cgID' from #PS5
	)X
go



if object_id ('tempdb..#TARGETFINAL') is not NULL
	drop table #TARGETFINAL
select
	distinct mergedcustomerid,
	customerGroup,
	cgID,
	'ControlGroup' 'targetGroup',
	1 'isControlGroup'
into
	#TARGETFINAL
from
	#TG_X
where
	Xile in (1,20)
union all
select
	distinct mergedcustomerid,
	customerGroup,
	cgID,
	'TargetGroup' 'targetGroup',
	0 'isControlGroup'
from
	#TG_X
where
	Xile not in (1,20)
go



select
	distinct cgID,
	customerGroup,
	count(distinct mergedcustomerid) 'cCount'
from
	#TARGETFINAL
group by
	customerGroup,
	cgID
order by
	cgID

