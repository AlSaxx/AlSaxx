if object_id ('tempdb..#SpM2_POTENTIAL') is not NULL
	drop table #SpM2_POTENTIAL
select
	distinct a.mergedcustomerid,
	count (distinct tat.title) 'topAssCount'
into
	#SpM2_POTENTIAL
from
	#ACTIVE_EM a (nolock)
	inner join expanededmergedcustomerids emc (nolock) on a.mergedcustomerid = emc.mergedcustomerid
	inner join transactions tc (nolock) on tc.insightcustomerid = emc.insightcustomerid
	inner join transactionitem ti (nolock) on tc.id = ti.transactionid
	inner join sku s (nolock) on ti.sku = s.sku
	inner join #TOPASSTITLES tat on s.title = tat.title
where
	transactiondate > cast(dateadd(month,-12,getdate()) as date)
	and	transactiontypeid = 1
	and a.mergedcustomerid not in (select distinct mergedcustomerid from #PREORDER)
	and a.mergedcustomerid not in (select distinct mergedcustomerid from #PreviousSpM)
group by
	a.mergedcustomerid
go


