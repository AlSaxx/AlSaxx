USE GAME_ARC
GO

--------------------------------------TEMP TABLES---------------------------------------
----------------------------------------------------------------------------------------

IF OBJECT_ID ('tempdb..#D@R') IS NOT NULL
	DROP TABLE #D@R

SELECT *
	INTO #D@R
	FROM DIM_PRODUCT P (NOLOCK)
	WHERE SOURCE_PRODUCT_CODE  IN ('238444','238446','238447','238448','238451','244884','345580','461554','746164','820515','820520')
GO

--SELECT * FROM #D@R

--------------------------------------DATA PULLS----------------------------------------
----------------------------------------------------------------------------------------

SELECT	[YEAR],
		WEEK_NUMBER_THIS_YEAR,
		Week_Commencing,
		COALESCE([PSN 5 GIFT CARD],0) 'PSN �5 Gift Card',
		COALESCE([PSN 10 GIFT CARD],0) 'PSN �10 Gift Card',
		COALESCE([PSN 15 GIFT CARD],0) 'PSN �15 Gift Card',
		COALESCE([PSN 20 GIFT CARD],0) 'PSN �20 Gift Card',
		COALESCE([PSN 25 GIFT CARD],0) 'PSN �25 Gift Card',
		COALESCE([PSN WALLET GIFT CARD 32],0) 'PSN �32 Gift Card',
		COALESCE([PSN 35 GIFT CARD],0) 'PSN �35 Gift Card',
		COALESCE([PSN 40 GIFT CARD],0) 'PSN �40 Gift Card',
		COALESCE([PSN 50 GIFT CARD],0) 'PSN �50 Gift Card',
		COALESCE([PSN WALLET GIFT CARD 84],0) 'PSN �84 Gift Card',
		COALESCE([WALLET GIFT CARD 100 GBP UK],0) 'PSN �100 Gift Card'
FROM
(
SELECT  D.[YEAR],
		D.WEEK_NUMBER_THIS_YEAR,
		CAST(DD.DATE_FLD as date) 'Week_Commencing',
		CASE
			WHEN P.SOURCE_PRODUCT_CODE IN ('238444') THEN 'PSN 5 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('238446') THEN 'PSN 10 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('238447') THEN 'PSN 15 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('238448') THEN 'PSN 25 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('238451') THEN 'PSN 35 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('244884') THEN 'PSN 20 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('345580') THEN 'PSN 40 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('461554') THEN 'PSN 50 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('746164') THEN 'WALLET GIFT CARD 100 GBP UK'
			WHEN P.SOURCE_PRODUCT_CODE IN ('820515') THEN 'PSN WALLET GIFT CARD 32'
			WHEN P.SOURCE_PRODUCT_CODE IN ('820520') THEN 'PSN WALLET GIFT CARD 84'
		END 'D@R',
		SUM(SALE_TOT_QTY) 'Unit_Sales'
	FROM FCT_SALES_LINES F (NOLOCK)
		INNER JOIN #D@R P ON P.PRODUCT_KEY = F.PRODUCT_KEY
		INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
		INNER JOIN DIM_DATE DD (NOLOCK) ON D.WEEK_ST_DATE_KEY = DD.DATE_KEY
	WHERE
		SALE_INVC_TYPE IN ('REG-INV', 'DISC-SALE') 
		AND D.DATE_FLD >= '2022-01-02' AND D.DATE_FLD < '2022-12-31'
		AND MERCHANDISE_FLG = 'YES'
	GROUP BY
		D.[YEAR],
		D.WEEK_NUMBER_THIS_YEAR,
		DD.DATE_FLD,
		CASE
			WHEN P.SOURCE_PRODUCT_CODE IN ('238444') THEN 'PSN 5 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('238446') THEN 'PSN 10 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('238447') THEN 'PSN 15 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('238448') THEN 'PSN 25 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('238451') THEN 'PSN 35 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('244884') THEN 'PSN 20 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('345580') THEN 'PSN 40 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('461554') THEN 'PSN 50 GIFT CARD'
			WHEN P.SOURCE_PRODUCT_CODE IN ('746164') THEN 'WALLET GIFT CARD 100 GBP UK'
			WHEN P.SOURCE_PRODUCT_CODE IN ('820515') THEN 'PSN WALLET GIFT CARD 32'
			WHEN P.SOURCE_PRODUCT_CODE IN ('820520') THEN 'PSN WALLET GIFT CARD 84'
		END
) X
PIVOT
(
	SUM(Unit_Sales)
		FOR D@R IN	(
					[PSN 5 GIFT CARD],
					[PSN 10 GIFT CARD],
					[PSN 15 GIFT CARD],
					[PSN 25 GIFT CARD],
					[PSN 35 GIFT CARD],
					[PSN 20 GIFT CARD],
					[PSN 40 GIFT CARD],
					[PSN 50 GIFT CARD],
					[WALLET GIFT CARD 100 GBP UK],
					[PSN WALLET GIFT CARD 32],
					[PSN WALLET GIFT CARD 84]
					)
) PVT
	ORDER BY
		[YEAR],
		WEEK_NUMBER_THIS_YEAR
GO

