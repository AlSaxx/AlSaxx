-------------------PRODUCT TABLES---------------
------------------------------------------------

IF OBJECT_ID ('tempdb..#PS5') IS NOT NULL
	DROP TABLE #PS5

SELECT *
	INTO #PS5
	FROM DIM_PRODUCT P (NOLOCK)
	WHERE SOURCE_PRODUCT_CODE IN ('749661','798801','798805','802049','802051','802053','802055','804431','818795',
								'818799','823229','823231','825298','825565','831692','833336','834508','835320',
								'837635','837822','837826','837853')
GO

