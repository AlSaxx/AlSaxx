SELECT	CASE
			WHEN T.TENDER_CODE = 'CA' THEN 'Cash'
			WHEN T.TENDER_CODE = 'CN' THEN 'Frasers+'
			WHEN T.TENDER_CODE = 'PP' THEN 'PayPal'
			WHEN T.TENDER_CODE IN ('FG','WG') THEN 'GiftCertificate'
			ELSE 'CreditCard'
		END 'PaymentMethod',
		COUNT(DISTINCT F.INVOICE_NO) 'Baskets'
	FROM #BSKT F (NOLOCK)
		INNER JOIN #TEND IT ON IT.INVOICE_NO = F.INVOICE_NO
		INNER JOIN DIM_TENDER T (NOLOCK) ON T.TENDER_KEY = IT.TENDER_KEY
	WHERE
		F.SALE_INVC_TYPE IN ('REG-INV','DISC-SALE')
	GROUP BY
		CASE
			WHEN T.TENDER_CODE = 'CA' THEN 'Cash'
			WHEN T.TENDER_CODE = 'CN' THEN 'Frasers+'
			WHEN T.TENDER_CODE = 'PP' THEN 'PayPal'
			WHEN T.TENDER_CODE IN ('FG','WG') THEN 'GiftCertificate'
			ELSE 'CreditCard'
		END
GO

