---------------FACT DETAIL TABLES---------------
------------------------------------------------

IF OBJECT_ID ('tempdb..#BSKT') IS NOT NULL
	DROP TABLE #BSKT

SELECT F.*
	INTO #BSKT
	FROM FCT_SALES_LINES F (NOLOCK)
		INNER JOIN #PS5 P (NOLOCK) ON P.PRODUCT_KEY = F.PRODUCT_KEY
		INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = F.DATE_KEY
	WHERE
		D.DATE_FLD >= '2023-11-03' AND D.DATE_FLD < '2024-04-01'
		AND SALE_INVC_TYPE IN ('REG-INV','DISC-SALE')
GO

IF OBJECT_ID ('tempdb..#TEND') IS NOT NULL
	DROP TABLE #TEND

SELECT IT.*
	INTO #TEND
	FROM FCT_SALES_INVOICE_TENDER IT (NOLOCK)
		INNER JOIN DIM_DATE D (NOLOCK) ON D.DATE_KEY = IT.DATE_KEY
	WHERE D.DATE_FLD >= '2023-11-03' AND D.DATE_FLD < '2024-04-01' 
		AND IT.INVOICE_NO IN (SELECT DISTINCT B.INVOICE_NO FROM #BSKT B)
GO

--------------------DATA PULLS------------------
------------------------------------------------

SELECT	COUNT(DISTINCT F.INVOICE_NO) 'Baskets'
	FROM #BSKT F (NOLOCK)
		INNER JOIN #TEND IT ON IT.INVOICE_NO = F.INVOICE_NO
		INNER JOIN DIM_TENDER T (NOLOCK) ON T.TENDER_KEY = IT.TENDER_KEY
	WHERE
		F.SALE_INVC_TYPE IN ('REG-INV','DISC-SALE')
GO

